{
  "name": "gitaudit",
  "displayName": "GitAudit",
  "description": "GitAudit webview extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitaudit.start",
        "title": "GitAudit: Show repo dashboard"
      },
      {
        "command": "gitaudit.analyze",
        "title": "GitAudit: Run repo analysis"
      }
    ]
  },
  "configurations": {
    "title": "GitAudit",
    "properties": {
      "gitaudit.minDaysSinceTouch": {
        "type": "number",
        "default": 60,
        "description": "Minimum days since last commit to flag a file as untouched"
      },
      "gitaudit.maxAuthors": {
        "type": "number",
        "default": 3,
        "description": "Files touched by this many of fewer authors are flagged as high risk as the knowledge base is limited to a smaller group"
      },
      "gitaudit.minCommits": {
        "type": "number",
        "default": 10,
        "description": "Files with fewer commits then this are ignored (too new to judge)"
      },
      "gitaudit.minBugFixRatio": {
        "type": "number",
        "default": 0.15,
        "minimum": 0,
        "maximum": 1,
        "description": "Files where this fraction or more of commits are bug fixes are flagged"
      },
      "gitaudit.minDangerScore": {
        "type": "number",
        "default": 40,
        "minimum": 0,
        "maximum": 100,
        "description": "Minimum danger score threshold for forbidden files detection"
      },
      "gitaudit.dangerScoreWeights": {
        "type": "object",
        "default": {
          "recency": 0.30,
          "ownership": 0.25,
          "bugMagnet": 0.30,
          "churnRate": 0.15
        },
        "description": "Weights for each component of the danger score. MUST SUM TO 1"
      },
      "gitaudit.cacheTTLHours": {
        "type": "number",
        "default": 24,
        "description": "How many hours before the cached analysis is considered stale"
      },
      "gitaudit.bugFixKeywords": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [
          "fix",
          "bug",
          "patch",
          "hotfix",
          "issue",
          "error",
          "crash",
          "defect",
          "regression",
          "broken"
        ],
        "description": "Commit message keywords used to identify bug-fix commits"
      },
      "gitaudit.refactorKeywords": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [
          "refactor",
          "cleanup",
          "clean up",
          "restructure"
        ],
        "description": "Commit message keywords used to identify code refactor commits"
      },
      "gitaudit.featureKeywords": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [
          "feature",
          "feat",
          "add",
          "new",
          "implement",
          "support"
        ],
        "description": "Commit message keywords used to identify code feature commits"
      },
      "gitaudit.exceptionFiles": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [
          "Dockerfile",
          "package.json",
          "package-lock.json"
        ],
        "description": "Commit message keywords used to identify code feature commits"
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "npm run build:extension && npm run build:webview",
    "watch": "npm run watch:extension & npm run watch:webview",
    "build:extension": "esbuild src/extension/extension.ts --bundle --outfile=dist/extension/extension.js --external:vscode --format=cjs --platform=node",
    "watch:extension": "esbuild src/extension/extension.ts --bundle --outfile=dist/extension/extension.js --external:vscode --format=cjs --platform=node --watch",
    "build:webview": "vite build",
    "watch:webview": "vite build --watch",
    "build": "npm run compile"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "18.x",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.19.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}